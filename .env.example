# IMAP server
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_SSL=true

# Account credentials — use app-specific password for Gmail / QQ / 163
IMAP_USERNAME=you@example.com
IMAP_PASSWORD=

# Folders to monitor — comma-separated, e.g. INBOX,Sent
IMAP_FOLDERS=INBOX

# API authentication — leave empty to disable (trusted network only)
IMAP_API_TOKEN=

# Tuning
IDLE_RECONNECT_INTERVAL=900
IMAP_MAIL_RETENTION_DAYS=365
INITIAL_SYNC_DAYS=30
FETCH_BODY=true
STORE_ATTACHMENTS=false
MAX_FETCH_SIZE=26214400
